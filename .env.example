# tackle — example environment file.
#
# Copy to `.env` in this same directory and edit:  cp .env.example .env
# tackle auto-loads a .env from the same directory as tackle.zsh (i.e. this file).
# Override the path by setting TACKLE_ENV_FILE in your shell rc *before* sourcing:
#   export TACKLE_ENV_FILE="$HOME/code-private/tackle/.env"   # explicit — same as the default
#   export TACKLE_ENV_FILE="$HOME/.config/tackle.env"         # custom location
#
# All TACKLE_* vars are optional. Caller-set env vars always win over this file.
typeset TACKLE_AGENT="claude"                        # AI agent to launch (e.g. cursor, codex)
typeset TACKLE_DIR_TEMPLATE="{repo}_{branch}"        # worktree dir name; placeholders: {repo} {branch} {input}
typeset TACKLE_PROMPT=""                             # default initial prompt for the agent (empty = no prompt)
typeset TACKLE_REPO_CHECK="local"                    # cross-repo guard for PR URLs: local | remote | off
# Example: typeset TACKLE_PROMPT="Summarize what changed in this branch and flag anything risky."
# Tip: for agents with slash commands (e.g. Claude Code), you can invoke a skill:
# typeset TACKLE_PROMPT="/pr-review"
# Prompt supports template variables: {branch} {pr_number} {pr_title} {pr_description}
# Example with variables:
# typeset TACKLE_PROMPT="PR #{pr_number}: {pr_title}
# {pr_description}
# Summarize what changed and flag anything risky."
